# Analytics configuration (all optional — unset = analytics disabled, app works fine).
# Copy to `.env.local` for local dev, and set as build-time env in CI / Cloudflare.

# PostHog product analytics.
# Project API key from PostHog → Settings → Project → "Project API Key".
# This is a PUBLISHABLE client key — safe to ship in the built site.
VITE_POSTHOG_KEY=

# PostHog ingestion host. EU (recommended for GDPR) or US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# NOTE: Traffic/audience analytics (visitors, geo, devices, referrers) is handled
# separately by Cloudflare Web Analytics — enable it in the Cloudflare Pages
# dashboard (Pages → your project → Web Analytics). No key needed; it auto-injects.
